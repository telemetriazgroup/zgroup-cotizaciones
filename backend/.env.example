PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_USER=zgroup
DB_PASSWORD=zgroup123
DB_NAME=zgroup_cotizaciones

# Módulo 0 — JWT y Redis (producción: usar secretos fuertes)
JWT_ACCESS_SECRET=cambiar-access-secret
JWT_REFRESH_SECRET=cambiar-refresh-secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_MS=604800000

# Redis (invalidación de refresh en logout). Opcional en local si no hay Redis.
REDIS_URL=redis://localhost:6379

# Primer usuario ADMIN (solo si la tabla users está vacía)
ZGROUP_ADMIN_EMAIL=admin@zgroup.local
ZGROUP_ADMIN_PASSWORD=Admin123!

# Superusuario fijo (se crea si no existe): login zgroup o zgroup@zgroup.local
ZGROUP_SUPER_PASSWORD=12345789
